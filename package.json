{
  "name": "sp-devcontrol",
  "version": "2.0.0",
  "description": "Local governance layer for AI-assisted software projects — cross-platform with daemon, REST API and MCP server",
  "type": "module",
  "bin": {
    "sp-devcontrol": "./dist/cli.js",
    "devcontrol": "./dist/cli.js"
  },
  "files": [
    "dist/",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "node dist/cli.js",
    "build": "tsc",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build && npm test",
    "pkg:linux": "pkg dist/cli.js --target node20-linux-x64 --output release/devcontrol-linux-x64 --compress GZip",
    "pkg:linux-arm": "pkg dist/cli.js --target node20-linux-arm64 --output release/devcontrol-linux-arm64 --compress GZip",
    "pkg:win": "pkg dist/cli.js --target node20-win-x64 --output release/devcontrol-win-x64.exe --compress GZip",
    "pkg:all": "npm run build && mkdir -p release && npm run pkg:linux && npm run pkg:linux-arm && npm run pkg:win",
    "deploy:cluster": "bash scripts/deploy-cluster.sh"
  },
  "pkg": {
    "assets": [
      "dist/**/*"
    ],
    "outputPath": "release"
  },
  "author": "SolucionesPro",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SolucionesPro/sp-devcontrol.git"
  },
  "keywords": [
    "governance",
    "ai-development",
    "cli",
    "devops",
    "code-quality",
    "security",
    "compliance",
    "agentic",
    "cursor",
    "claude",
    "copilot"
  ],
  "dependencies": {
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "chokidar": "^4.0.3",
    "cli-table3": "^0.6.5",
    "commander": "^13.1.0",
    "diff": "^8.0.2",
    "execa": "^9.5.2",
    "express": "^4.21.2",
    "inquirer": "^12.5.2",
    "simple-git": "^3.27.0",
    "ws": "^8.18.2",
    "@modelcontextprotocol/sdk": "^1.13.0"
  },
  "devDependencies": {
    "@types/diff": "^7.0.0",
    "@types/express": "^4.17.21",
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.14",
    "@yao-pkg/pkg": "^5.16.1",
    "typescript": "^5.7.3",
    "vitest": "^3.2.3"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
